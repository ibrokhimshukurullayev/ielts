generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// SQLite has no enum support, so Skill is a plain String.
// Allowed values: "READING" | "LISTENING" | "WRITING" | "SPEAKING" (see src/shared/config/skills.js).
// Switching to Postgres later: change provider above and optionally reintroduce an enum.

// role: "STUDENT" | "TEACHER" (see src/shared/config/roles.js)
model User {
  id           String    @id @default(cuid())
  username     String    @unique
  name         String
  email        String?   @unique
  passwordHash String
  role         String    @default("STUDENT")
  teacherId    String?
  teacher      User?     @relation("TeacherStudents", fields: [teacherId], references: [id])
  students     User[]    @relation("TeacherStudents")
  targetBand   Float?
  examDate     DateTime?
  currentBand  Float?
  weeklyHours  Int?
  focusSkill   String?
  createdAt    DateTime  @default(now())
  attempts                  Attempt[]
  teacherConversations      Conversation[]   @relation("TeacherConversations")
  studentConversations      Conversation[]   @relation("StudentConversations")
  posts                     Post[]           @relation("TeacherPosts")
  comments                  Comment[]        @relation("CommentSenders")
  studentWritingReviews     WritingReview[]  @relation("StudentWritingReviews")
  teacherWritingReviews     WritingReview[]  @relation("TeacherWritingReviews")
}

// 1-on-1 conversation between one teacher and one student.
model Conversation {
  id        String    @id @default(cuid())
  teacherId String
  teacher   User      @relation("TeacherConversations", fields: [teacherId], references: [id])
  studentId String
  student   User      @relation("StudentConversations", fields: [studentId], references: [id])
  messages  Message[]
  createdAt DateTime  @default(now())

  @@unique([teacherId, studentId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  text           String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([conversationId])
}

// Group board: teacher writes posts, students/teacher comment on them.
model Post {
  id        String    @id @default(cuid())
  teacherId String
  teacher   User      @relation("TeacherPosts", fields: [teacherId], references: [id])
  text      String
  comments  Comment[]
  createdAt DateTime  @default(now())
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation("CommentSenders", fields: [senderId], references: [id])
  text      String
  createdAt DateTime @default(now())

  @@index([postId])
}

model VerificationCode {
  id        String   @id @default(cuid())
  email     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Test {
  id        String    @id @default(cuid())
  skill     String
  slug      String    @unique
  title     String
  content   Json
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  attempts  Attempt[]
}

model Attempt {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  testId       String?
  test         Test?    @relation(fields: [testId], references: [id])
  skill        String
  band         Float
  correctCount Int?
  total        Int?
  details      Json?
  createdAt    DateTime @default(now())
}

// status: "PENDING" | "REVIEWED"
model WritingReview {
  id              String   @id @default(cuid())
  studentId       String
  student         User     @relation("StudentWritingReviews", fields: [studentId], references: [id])
  teacherId       String
  teacher         User     @relation("TeacherWritingReviews", fields: [teacherId], references: [id])
  testId          String?
  taskTitle       String
  prompt          String
  essay           String
  wordCount       Int
  taskNumber      Int      @default(1)
  aiBand          Float?
  teacherFeedback String?
  teacherBand     Float?
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([studentId])
  @@index([teacherId])
}
